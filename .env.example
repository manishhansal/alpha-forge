# Copy this file to .env.local and fill in. The defaults below match docker-compose.yml.

# --- Public (browser-exposed) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BINANCE_WS=wss://stream.binance.com:9443/stream
NEXT_PUBLIC_BINANCE_FUTURES_WS=wss://fstream.binance.com/stream
NEXT_PUBLIC_BYBIT_WS=wss://stream.bybit.com/v5/public/linear
# Delta Exchange India public socket (ticker / candlesticks / funding_rate).
NEXT_PUBLIC_DELTA_WS=wss://public-socket.india.delta.exchange

# --- Broker selection ---
# Which exchange the dashboard talks to for public market data. The browser
# reads NEXT_PUBLIC_ACTIVE_BROKER; the server prefers ACTIVE_BROKER but falls
# back to the public value. Allowed: `delta` (default, India INR-settled
# perpetuals on BTCUSD/ETHUSD/SOLUSD) or `binance` (global USDT-perp).
ACTIVE_BROKER=delta
NEXT_PUBLIC_ACTIVE_BROKER=delta
# Override for Delta REST base — point to testnet by setting
# `https://cdn-ind.testnet.deltaex.org` if needed.
DELTA_REST_BASE_URL=https://api.india.delta.exchange

# --- Database (Postgres via docker-compose) ---
# docker-compose maps Postgres to host port 5433 (5432 is often taken by a
# native install). User/pass/db match docker-compose.yml.
DATABASE_URL=postgresql://crypto:crypto@localhost:5433/crypto_dashboard

# --- Cache (Redis via docker-compose) ---
REDIS_URL=redis://localhost:6379

# --- Optional 3rd-party APIs ---
COINGECKO_API_KEY=
COINGLASS_API_KEY=
DERIBIT_CLIENT_ID=
DERIBIT_SECRET=

# --- Angel One SmartAPI (India option-chain primary source) ---
# Register a SmartAPI app at https://smartapi.angelone.in/ to obtain your API
# key. When all four vars below are present, /api/in/option-chain uses Angel
# One as the primary source (ScripMaster + Quote + optionGreek) and falls back
# to the NSE library automatically on any failure. When unset, the route uses
# only the NSE library — no behaviour change.
SMARTAPI_API_KEY=
# Your AngelOne client/trading ID (e.g. A12345).
SMARTAPI_CLIENT_CODE=
# Your 4-digit MPIN (NOT your web password).
SMARTAPI_PIN=
# TOTP secret shown when you enabled 2FA (base32 string from the QR code).
SMARTAPI_TOTP_SECRET=
# Optional — only set if you want fixed IP/MAC headers in SmartAPI requests.
SMARTAPI_LOCAL_IP=
SMARTAPI_PUBLIC_IP=
SMARTAPI_MAC_ADDRESS=

# --- Auth.js v5 ---
# Generate with: `npx auth secret` (or `openssl rand -hex 32`). 32+ chars required.
AUTH_SECRET=
# Set to "true" when running behind a reverse proxy (e.g. Vercel, Fly, Railway).
AUTH_TRUST_HOST=true

# --- Sensitive-field encryption (AES-256-GCM) ---
# 64 hex chars (= 32 bytes). Generate with: `openssl rand -hex 32`.
# Required only when a user saves exchange API keys in Settings.
ENCRYPTION_KEY=

# --- Alert delivery channels (optional) ---
# Resend API key for email alerts. https://resend.com
RESEND_API_KEY=
ALERT_EMAIL_FROM="Alphaforge <alerts@example.com>"
# Signing secret for outbound webhooks (used in X-Crypto-Desk-Signature header).
# Generate with: `openssl rand -hex 24`.
ALERT_WEBHOOK_SIGNING_SECRET=

# --- Worker tuning (all optional, sensible defaults baked in) ---
# Comma-separated Binance futures symbols to track for liquidations.
# Default: BTCUSDT,ETHUSDT,SOLUSDT
WORKER_LIQUIDATION_SYMBOLS=
WORKER_SIGNAL_INGEST_INTERVAL_MS=60000
WORKER_SIGNAL_OUTCOME_INTERVAL_MS=300000
WORKER_ALERTS_INTERVAL_MS=30000
# Base URL the worker hits to drive `/api/signals` (defaults to NEXT_PUBLIC_APP_URL).
WORKER_APP_BASE_URL=http://localhost:3000

# --- Worker logging ---
# Log threshold. Defaults: info in production, debug otherwise.
WORKER_LOG_LEVEL=
# Output format: `pretty` (default in dev) or `json` (default in prod). JSON is
# one structured record per line, ready to ship to Datadog / Loki / CloudWatch.
WORKER_LOG_FORMAT=
# Service tag used in JSON logs and Sentry events. Defaults to `crypto-desk-worker`.
WORKER_SERVICE_NAME=

# --- Sentry (optional; worker only) ---
# When unset, every Sentry call in the worker is a no-op.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# 0..1; tracing has CPU cost — leave at 0 unless you specifically want it.
SENTRY_TRACES_SAMPLE_RATE=0
