{
  "name": "alphaforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:big": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next dev",
    "dev:tdd": "concurrently --kill-others-on-fail --prefix-colors auto -n next,vitest \"npm:dev\" \"npm:test:watch\"",
    "prebuild": "npm test",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit && tsc --noEmit -p worker/tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:lib": "vitest run tests/lib",
    "test:features": "vitest run tests/features",
    "test:components": "vitest run tests/components",
    "test:api": "vitest run tests/api",
    "test:services": "vitest run tests/services",
    "test:hooks": "vitest run tests/hooks",
    "test:stores": "vitest run tests/stores",
    "test:pages": "vitest run tests/pages",
    "test:worker": "vitest run tests/worker",
    "test:all": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=./test-results/junit.xml",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio --config ./prisma.config.ts",
    "worker:dev": "tsx --conditions=react-server --env-file=.env.local worker/src/index.ts",
    "worker:big": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsx --conditions=react-server --env-file=.env.local worker/src/index.ts",
    "worker:watch": "tsx watch --conditions=react-server --env-file=.env.local worker/src/index.ts",
    "worker:start": "tsx --conditions=react-server --env-file=.env.local worker/src/index.ts",
    "setup": "npm install && npm run docker:up && npm run db:migrate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/node": "^10.53.1",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "server-only": "^0.0.1",
    "stock-nse-india": "^1.3.0",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.1",
    "yahoo-finance2": "^3.14.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  }
}
